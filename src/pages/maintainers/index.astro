---
import Base from "../../layouts/Base.astro";
---
<Base title="Maintainers - rust-nostr" description="Active maintainers of the rust-nostr project.">
  <main class="page">
    <section class="page-hero">
      <p class="eyebrow">Maintainers</p>
      <h1>People maintaining rust-nostr.</h1>
      <p>Active maintainers for the project and its libraries.</p>
    </section>

    <section class="team-list" aria-label="Active maintainers">
      <article class="team-member">
        <div class="member-avatar" aria-hidden="true">YK</div>
        <div class="member-body">
          <h2>Yuki Kishimoto</h2>
          <p>Project maintainer and lead developer.</p>
          <div class="member-links">
            <a href="mailto:yukikishimoto@protonmail.com">Email</a>
            <a href="https://yukikishimoto.com">Website</a>
          </div>
        </div>
      </article>

      <article class="team-member">
        <div class="member-avatar" aria-hidden="true">A</div>
        <div class="member-body">
          <h2>Awiteb</h2>
          <p>Project maintainer and contributor.</p>
          <div class="member-links">
            <a href="mailto:a@4rs.nl">Email</a>
            <a href="https://4rs.nl">Website</a>
          </div>
        </div>
      </article>
    </section>
  </main>
</Base>
