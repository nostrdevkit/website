---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../utils/paths";
---
<Base title="Patrons - rust-nostr" description="Special thanks to significant supporters of rust-nostr development.">
  <main class="page">
    <section class="page-hero">
      <p class="eyebrow">Patrons</p>
      <h1>Special thanks to our supporters.</h1>
      <p>
        rust-nostr is free and open-source. These patrons have provided significant support
        for its ongoing development and maintenance.
      </p>
    </section>

    <section class="patron-list" aria-label="rust-nostr patrons">
      <article>
        <h2><a href="https://opensats.org">OpenSats</a></h2>
        <p>
          OpenSats supports open-source contributors working on freedom tech and bitcoin-related projects.
        </p>
      </article>
      <article>
        <h2><a href="https://github.com/smartvaults">SmartVaults</a></h2>
        <p>
          SmartVaults develops multi-custody Bitcoin software that leverages nostr for signature orchestration.
        </p>
      </article>
    </section>

    <section class="content-section">
      <p>
        If you or your organization want to support rust-nostr development, please{" "}
        <a href={withBase("/maintainers/")}>contact the maintainers</a>.
      </p>
    </section>
  </main>
</Base>
