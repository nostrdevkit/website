---
import { withBase } from "../utils/paths";

const {
  title = "rust-nostr",
  description = "rust-nostr is a fast, reliable nostr development kit for multiple languages and runtimes.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={withBase("/assets/logo.svg")} type="image/svg+xml" />
    <link rel="stylesheet" href={withBase("/styles.css")} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="rust-nostr home">
        <img class="brand-mark" src={withBase("/assets/logo.svg")} alt="" width="36" height="36" />
        <span>rust-nostr</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="https://doc.rust-nostr.org/">Docs</a>
        <a href="https://github.com/rust-nostr/nostr">GitHub</a>
        <a class="nav-action" href={withBase("/donate/")}>Donate</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div>
        <a class="footer-brand" href={withBase("/")}>
          <img class="brand-mark" src={withBase("/assets/logo.svg")} alt="" width="32" height="32" />
          <span>rust-nostr</span>
        </a>
        <p>Fast and reliable nostr libraries for multiple languages and runtimes.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href={withBase("/maintainers/")}>Maintainers</a>
        <a href={withBase("/patrons/")}>Patrons</a>
        <a href={withBase("/donate/")}>Donate</a>
        <a href={withBase("/license/")}>License</a>
      </nav>
    </footer>
  </body>
</html>
